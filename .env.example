# =============================================================================
# PyWallet — Environment Variable Reference
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ----- Application -----
APP_NAME=PyWallet
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-64-char-random-string-in-production

# ----- PostgreSQL -----
# Format: postgresql+asyncpg://user:password@host:port/dbname
POSTGRES_USER=pywallet_user
POSTGRES_PASSWORD=pywallet_pass
POSTGRES_DB=pywallet_db
POSTGRES_HOST=postgres        # Docker service name; use 'localhost' outside Docker
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://pywallet_user:pywallet_pass@postgres:5432/pywallet_db

# ----- Redis -----
REDIS_HOST=redis              # Docker service name; use 'localhost' outside Docker
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ----- Celery -----
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----- JWT (Phase 2) -----
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
